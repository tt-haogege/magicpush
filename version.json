{
  "name": "magicpush",
  "version": "1.3.0",
  "displayName": "MagicPush",
  "description": "支持多渠道消息推送的统一管理平台",
  "repository": {
    "type": "git",
    "url": "https://github.com/magiccode1412/magicpush"
  },
  "changelog": [
    {
      "version": "1.3.0",
      "date": "2026-03-20",
      "type": "release",
      "changes": [
        "新增SMTP邮件通知渠道，支持QQ邮箱、163邮箱、Gmail等主流邮箱服务"
      ]
    },
    {
      "version": "1.2.5",
      "date": "2026-03-11",
      "type": "release",
      "changes": [
        "修复入站配置保存时错误触发接口令牌重新生成的问题"
      ]
    },
    {
      "version": "1.2.4",
      "date": "2026-03-10",
      "type": "release",
      "changes": [
        "新增API接口CF代理支持",
        "新增通知渠道代理功能（支持Telegram等需要代理的渠道）"
      ]
    },
    {
      "version": "1.2.3",
      "date": "2026-03-09",
      "type": "release",
      "changes": [
        "新增入站 Webhook 配置功能",
        "支持字段映射（JSONPath）",
        "内置 Grafana、Prometheus、GitHub、Emby 预设模板",
        "支持 GET/POST 请求方式",
        "消息内容自动丰富化"
      ]
    },
    {
      "version": "1.2.2",
      "date": "2026-03-08",
      "type": "release",
      "changes": [
        "修复未有管理员用户时自动跳转到注册页面",
        "即将发布飞牛NAS部署方式"
      ]
    },
    {
      "version": "1.2.1",
      "date": "2026-03-05",
      "type": "release",
      "changes": [
        "修复Webhook渠道Body模板变量未转义导致JSON格式错误的问题",
        "优化Webhook模板解析失败时的错误处理，改为返回默认JSON格式"
      ]
    },
    {
      "version": "1.2.0",
      "date": "2026-03-03",
      "type": "release",
      "changes": [
        "新增微信公众号渠道支持（模板消息推送）",
        "新增Server酱渠道支持（微信推送服务）"
      ]
    },
    {
      "version": "1.1.0",
      "date": "2026-03-03",
      "type": "release",
      "changes": [
        "JWT_SECRET 支持自动生成，首次运行时自动创建安全密钥并存入数据库",
        "移除不安全的环境变量默认值",
        "简化 Docker 部署配置，JWT_SECRET 变为可选项"
      ]
    },
    {
      "version": "1.0.0",
      "date": "2026-03-02",
      "type": "release",
      "changes": [
        "首发"
      ]
    }
  ]
}
